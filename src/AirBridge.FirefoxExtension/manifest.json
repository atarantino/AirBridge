{
  "manifest_version": 3,
  "name": "AirBridge Video Sync",
  "version": "0.3.0",
  "description": "Delays HTML5 video pictures to align them with AirPlay audio routed by AirBridge.",
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "96": "icons/icon-96.png", "128": "icons/icon-128.png" },
  "permissions": ["activeTab", "storage"],
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["sync-core.js", "content.js"], "run_at": "document_idle", "all_frames": true }],
  "action": { "default_title": "AirBridge picture delay", "default_popup": "popup.html", "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png" } },
  "browser_specific_settings": {
    "gecko": {
      "id": "airbridge-video-sync@airbridge.local",
      "strict_min_version": "128.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
